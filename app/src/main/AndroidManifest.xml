<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- NFC support (optional — for future NDEF tag reading) -->
    <!-- <uses-permission android:name="android.permission.NFC" /> -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Found-cache collection list (launcher) -->
        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- QR scanner + assembler; also handles tagdrop:// deep links -->
        <activity
            android:name=".ReceiveActivity"
            android:label="@string/title_scan"
            android:exported="true"
            android:parentActivityName=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="tagdrop" />
            </intent-filter>
        </activity>

        <!-- WebView content display -->
        <activity
            android:name=".ViewDataUriActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:label="Content"
            android:exported="false"
            android:parentActivityName=".ReceiveActivity">
            <!-- data: URI intent filter so openWebPage works via implicit intents -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="data" />
            </intent-filter>
        </activity>

        <!-- Cache creator / QR generator -->
        <activity
            android:name=".CreateActivity"
            android:label="@string/title_create"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- Collection detail ("map" of a collection's pages) -->
        <activity
            android:name=".CollectionDetailActivity"
            android:label="@string/title_collection_detail"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- In-app README viewer -->
        <activity
            android:name=".ReadMeActivity"
            android:label="@string/title_activity_read_me"
            android:exported="false"
            android:parentActivityName=".ReceiveActivity" />

    </application>

</manifest>
