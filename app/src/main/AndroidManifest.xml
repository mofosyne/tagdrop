<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- NFC support (optional — for future NDEF tag reading) -->
    <!-- <uses-permission android:name="android.permission.NFC" /> -->

    <application
        android:name=".TagDropApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Found-cache collection list (launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- QR scanner + assembler; also handles tagdrop: deep links -->
        <activity
            android:name=".ReceiveActivity"
            android:label="@string/title_scan"
            android:exported="true"
            android:parentActivityName=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="tagdrop" />
            </intent-filter>
        </activity>

        <!-- WebView content display -->
        <activity
            android:name=".ViewDataUriActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:label="Content"
            android:exported="true"
            android:parentActivityName=".ReceiveActivity">
            <!-- data: URI intent filter so openWebPage works via implicit intents -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="data" />
            </intent-filter>
        </activity>

        <!-- Cache creator / QR generator -->
        <activity
            android:name=".CreateActivity"
            android:label="@string/title_create"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- Multi-file paper layout creator / printable QR sheet -->
        <activity
            android:name=".CreatePaperActivity"
            android:label="@string/title_create_paper"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- Collection detail ("map" of a collection's pages) -->
        <activity
            android:name=".CollectionDetailActivity"
            android:label="@string/title_collection_detail"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Cycling QR display for sharing a cached item to another device's scanner -->
        <activity
            android:name=".ShareQrActivity"
            android:label="@string/title_share_qr"
            android:exported="false"
            android:parentActivityName=".CollectionDetailActivity" />

        <!-- In-app README viewer -->
        <activity
            android:name=".ReadMeActivity"
            android:label="@string/title_activity_read_me"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Retained AES key management (SPEC §9) -->
        <activity
            android:name=".RetainedKeysActivity"
            android:label="@string/title_retained_keys"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Exposes cached content as content:// URIs for "Open with…" / "Share" -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
